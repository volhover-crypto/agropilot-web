# .env.example — AgroPILOT backend environment variables
# Copy to .env and fill in real values. Never commit .env to git.

# PostgreSQL async connection string (asyncpg driver)
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+asyncpg://postgres:CHANGEME@localhost:5432/agropilot

# JWT settings (placeholder — replace before production)
SECRET_KEY=CHANGEME_replace_with_long_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
